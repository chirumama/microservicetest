            "nullable": true
          },
          "uriPattern": {
            "type": "string",
            "nullable": true
          },
          "upstreamId": {
            "type": "string",
            "nullable": true
          },
          "host": {
            "type": "string",
            "nullable": true
          },
          "port": {
            "type": "integer",
            "format": "int32"
          },
          "rewriteFrom": {
            "type": "string",
            "nullable": true
          },
          "rewriteTo": {
            "type": "string",
            "nullable": true
