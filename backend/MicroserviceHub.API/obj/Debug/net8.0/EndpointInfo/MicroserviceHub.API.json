            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateRouteAccessRequest": {
        "type": "object",
        "properties": {
          "routes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RouteToggle"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
